DATABASE_URL=sqlite:///./tamilar_calendar.db

# Optional Prokerala API (free tier at https://api.prokerala.com)
# Without these, ingestion uses kaalavidya (free local computation).
PROKERALA_CLIENT_ID=
PROKERALA_CLIENT_SECRET=

# Firebase service account JSON for FCM push (posts, metal rates, temples, morning).
# 1. Firebase Console → Project Settings → Service accounts → Generate new private key
# 2. Save the file as api/firebase-service-account.json (gitignored)
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# Origin phones can reach for post push images (LAN IP during dev, HTTPS domain in prod).
PUBLIC_BASE_URL=http://192.168.1.8:4000

# Admin panel password (required — set a strong value before exposing the API).
ADMIN_PASSWORD=change-me-to-a-strong-password

# OpenAI is used to rephrase the scraped Tamil daily raasi palan.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Set to true to auto-run daily raasi-palan sync at random times 04:00–06:00 IST.
# Default (false) means it only runs when the admin clicks "Fetch & update" in the panel.
RAASI_PALAN_AUTO_SYNC_ENABLED=false
